# Supabase project URL (https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to ship to the browser, RLS protects rows.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — server-side only. Used by ETL routes for bulk inserts
# that bypass RLS (price snapshots, reference data, etc.).
SUPABASE_SERVICE_ROLE_KEY=
